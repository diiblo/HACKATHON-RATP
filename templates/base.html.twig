<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>{% block title %}RATP — Signalements{% endblock %}</title>
    <link rel="icon" href="data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 128 128%22><rect width=%22128%22 height=%22128%22 rx=%2220%22 fill=%22%23003189%22/><text y=%221.05em%22 font-size=%2278%22 x=%2210%22 fill=%22%23fff%22 font-weight=%22bold%22>R</text></svg>">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet">
    <style>
        :root { --ratp-blue: #003189; --ratp-blue-dark: #001f5a; }
        body { background-color: #f4f6fb; }
        .sidebar {
            background-color: var(--ratp-blue);
            min-height: calc(100vh - 56px);
            padding-top: 1rem;
        }
        .sidebar .nav-link {
            color: rgba(255, 255, 255, 0.82);
            border-radius: 6px;
            margin: 2px 8px;
            padding: 8px 12px;
            font-size: 0.9rem;
        }
        .sidebar .nav-link:hover,
        .sidebar .nav-link.active {
            color: #fff;
            background-color: rgba(255, 255, 255, 0.15);
        }
        .sidebar .nav-link i { margin-right: 6px; }
        .sidebar .nav-link-action {
            color: #fff;
            background-color: rgba(25, 135, 84, 0.75);
            margin: 6px 8px;
        }
        .sidebar .nav-link-action:hover {
            background-color: rgba(25, 135, 84, 1);
            color: #fff;
        }
        .sidebar .sidebar-section {
            color: rgba(255,255,255,0.45);
            font-size: 0.72rem;
            text-transform: uppercase;
            letter-spacing: .08em;
            padding: 1rem 20px 4px;
        }
        .navbar-brand strong { letter-spacing: -0.5px; }
        .card { border: none; box-shadow: 0 1px 4px rgba(0,0,0,.08); }
        .stat-card { border-left: 4px solid var(--ratp-blue); }
        .badge-gravite-faible { background-color: #198754; }
        .badge-gravite-moyen  { background-color: #ffc107; color: #000; }
        .badge-gravite-grave  { background-color: #dc3545; }
        .timeline { position: relative; padding-left: 28px; }
        .timeline::before { content: ''; position: absolute; left: 10px; top: 0; bottom: 0; width: 2px; background: #dee2e6; }
        .timeline-item { position: relative; margin-bottom: 1.2rem; }
        .timeline-dot { position: absolute; left: -23px; top: 3px; width: 12px; height: 12px; border-radius: 50%; background: var(--ratp-blue); border: 2px solid #fff; box-shadow: 0 0 0 2px var(--ratp-blue); }
        .main-content { min-height: calc(100vh - 56px); }
        #sidebarMobile .nav-link { color: rgba(255,255,255,0.82); border-radius: 6px; margin: 2px 8px; padding: 8px 12px; font-size: 0.9rem; }
        #sidebarMobile .nav-link:hover, #sidebarMobile .nav-link.active { color: #fff; background-color: rgba(255,255,255,0.15); }
        #sidebarMobile .nav-link i { margin-right: 6px; }
        #sidebarMobile .nav-link-action { color: #fff; background-color: rgba(25,135,84,0.75); margin: 6px 8px; }
        #sidebarMobile .nav-link-action:hover { background-color: rgba(25,135,84,1); }
        #sidebarMobile .sidebar-section { color: rgba(255,255,255,0.45); font-size: 0.72rem; text-transform: uppercase; letter-spacing: .08em; padding: 1rem 20px 4px; }
    </style>
    {% block stylesheets %}{% endblock %}
</head>
<body>

{# Navbar top #}
<nav class="navbar navbar-dark py-0" style="background-color: var(--ratp-blue); height: 56px;">
    <div class="container-fluid">
        <div class="d-flex align-items-center gap-2">
            {% if app.user %}
            <button class="btn btn-outline-light btn-sm d-md-none me-1" data-bs-toggle="offcanvas" data-bs-target="#sidebarMobile" aria-label="Menu">
                <i class="bi bi-list fs-5"></i>
            </button>
            {% endif %}
            <a class="navbar-brand d-flex align-items-center gap-2" href="{{ path('app_dashboard') }}">
                <span class="fw-bold fs-5">RATP</span>
                <span class="text-white-50 fw-light">|</span>
                <span class="fw-light small">Gestion des signalements</span>
            </a>
        </div>
        {% if app.user %}
        <div class="d-flex align-items-center gap-3">
            <div class="text-white-75 small d-none d-md-block">
                <i class="bi bi-person-circle me-1"></i>
                <strong>{{ app.user.prenom }} {{ app.user.nom }}</strong>
                <span class="text-white-50 ms-1">({{ app.user.centre ?? 'N/A' }})</span>
            </div>
            <a href="{{ path('app_logout') }}" class="btn btn-outline-light btn-sm">
                <i class="bi bi-box-arrow-right me-1"></i>Déconnexion
            </a>
        </div>
        {% endif %}
    </div>
</nav>

{# Offcanvas sidebar — mobile #}
{% if app.user %}
<div class="offcanvas offcanvas-start" id="sidebarMobile" tabindex="-1" style="background-color: var(--ratp-blue); max-width: 260px;">
    <div class="offcanvas-header border-bottom border-white border-opacity-10">
        <span class="text-white fw-bold"><i class="bi bi-list me-2"></i>Menu</span>
        <button type="button" class="btn-close btn-close-white" data-bs-dismiss="offcanvas" aria-label="Fermer"></button>
    </div>
    <div class="offcanvas-body p-0">
        <ul class="nav flex-column pt-2">
            <li class="nav-item">
                <a class="nav-link {% if app.request.attributes.get('_route') starts with 'app_dashboard' %}active{% endif %}"
                   href="{{ path('app_dashboard') }}" data-bs-dismiss="offcanvas">
                    <i class="bi bi-speedometer2"></i> Tableau de bord
                </a>
            </li>
            <li class="nav-item">
                <a class="nav-link {% if app.request.attributes.get('_route') starts with 'app_signalement' %}active{% endif %}"
                   href="{{ path('app_signalement_index') }}" data-bs-dismiss="offcanvas">
                    <i class="bi bi-flag"></i> Signalements
                </a>
            </li>
            <li class="nav-item">
                <a class="nav-link {% if app.request.attributes.get('_route') starts with 'app_agent' %}active{% endif %}"
                   href="{{ path('app_agent_index') }}" data-bs-dismiss="offcanvas">
                    <i class="bi bi-people"></i> Agents
                </a>
            </li>

            {% if is_granted('ROLE_MANAGER') %}
            <li class="nav-item">
                <a class="nav-link {% if app.request.attributes.get('_route') starts with 'app_social' %}active{% endif %}"
                   href="{{ path('app_social_inbox') }}" data-bs-dismiss="offcanvas">
                    <i class="bi bi-chat-dots"></i> Signalements réseaux sociaux
                </a>
            </li>
            {% endif %}

            {% if is_granted('ROLE_RH') %}
            <div class="sidebar-section">Ressources humaines</div>
            <li class="nav-item">
                <a class="nav-link {% if app.request.attributes.get('_route') starts with 'app_courrier_' %}active{% endif %}"
                   href="{{ path('app_courrier_index') }}" data-bs-dismiss="offcanvas">
                    <i class="bi bi-envelope-paper"></i> Courriers à valider
                </a>
            </li>
            {% endif %}

            {% if is_granted('ROLE_ADMIN') %}
            <div class="sidebar-section">Administration</div>
            <li class="nav-item">
                <a class="nav-link {% if app.request.attributes.get('_route') starts with 'app_admin' %}active{% endif %}"
                   href="{{ path('app_admin_users') }}" data-bs-dismiss="offcanvas">
                    <i class="bi bi-person-gear"></i> Utilisateurs
                </a>
            </li>
            {% endif %}
            {% if is_granted('ROLE_DEV') %}
            <li class="nav-item">
                <a class="nav-link {% if app.request.attributes.get('_route') starts with 'app_admin_ai' %}active{% endif %}"
                   href="{{ path('app_admin_ai_configs') }}" data-bs-dismiss="offcanvas">
                    <i class="bi bi-cpu"></i> Configuration IA
                </a>
            </li>
            <li class="nav-item">
                <a class="nav-link {% if app.request.attributes.get('_route') starts with 'app_admin_audit' %}active{% endif %}"
                   href="{{ path('app_admin_audit') }}" data-bs-dismiss="offcanvas">
                    <i class="bi bi-journal-text"></i> Journal d'audit
                </a>
            </li>
            {% endif %}
        </ul>
    </div>
</div>
{% endif %}

<div class="container-fluid p-0">
    <div class="row g-0">

        {# Sidebar desktop #}
        {% if app.user %}
        <nav class="col-md-2 col-lg-2 sidebar d-none d-md-block">
            <ul class="nav flex-column">
                <li class="nav-item">
                    <a class="nav-link {% if app.request.attributes.get('_route') starts with 'app_dashboard' %}active{% endif %}"
                       href="{{ path('app_dashboard') }}">
                        <i class="bi bi-speedometer2"></i> Tableau de bord
                    </a>
                </li>
                <li class="nav-item">
                    <a class="nav-link {% if app.request.attributes.get('_route') starts with 'app_signalement' %}active{% endif %}"
                       href="{{ path('app_signalement_index') }}">
                        <i class="bi bi-flag"></i> Signalements
                    </a>
                </li>
                <li class="nav-item">
                    <a class="nav-link {% if app.request.attributes.get('_route') starts with 'app_agent' %}active{% endif %}"
                       href="{{ path('app_agent_index') }}">
                        <i class="bi bi-people"></i> Agents
                    </a>
                </li>

                {% if is_granted('ROLE_MANAGER') %}
                <li class="nav-item">
                    <a class="nav-link {% if app.request.attributes.get('_route') starts with 'app_social' %}active{% endif %}"
                       href="{{ path('app_social_inbox') }}">
                        <i class="bi bi-chat-dots"></i> Signalements réseaux sociaux
                    </a>
                </li>
                {% endif %}

                {% if is_granted('ROLE_RH') %}
                <div class="sidebar-section">Ressources humaines</div>
                <li class="nav-item">
                    <a class="nav-link {% if app.request.attributes.get('_route') starts with 'app_courrier_' %}active{% endif %}"
                       href="{{ path('app_courrier_index') }}">
                        <i class="bi bi-envelope-paper"></i> Courriers à valider
                    </a>
                </li>
                {% endif %}

                {% if is_granted('ROLE_ADMIN') %}
                <div class="sidebar-section">Administration</div>
                <li class="nav-item">
                    <a class="nav-link {% if app.request.attributes.get('_route') starts with 'app_admin' %}active{% endif %}"
                       href="{{ path('app_admin_users') }}">
                        <i class="bi bi-person-gear"></i> Utilisateurs
                    </a>
                </li>
                {% endif %}
                {% if is_granted('ROLE_DEV') %}
                <li class="nav-item">
                    <a class="nav-link {% if app.request.attributes.get('_route') starts with 'app_admin_ai' %}active{% endif %}"
                       href="{{ path('app_admin_ai_configs') }}">
                        <i class="bi bi-cpu"></i> Configuration IA
                    </a>
                </li>
                <li class="nav-item">
                    <a class="nav-link {% if app.request.attributes.get('_route') starts with 'app_admin_audit' %}active{% endif %}"
                       href="{{ path('app_admin_audit') }}">
                        <i class="bi bi-journal-text"></i> Journal d'audit
                    </a>
                </li>
                {% endif %}
            </ul>
        </nav>
        {% endif %}

        {# Main content #}
        <main class="{% if app.user %}col-md-10 col-lg-10{% else %}col-12{% endif %} main-content p-4">
            {# Flash messages #}
            {% for type, messages in app.flashes %}
                {% for message in messages %}
                    <div class="alert alert-{{ type == 'error' ? 'danger' : type }} alert-dismissible fade show" role="alert">
                        {{ message }}
                        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                    </div>
                {% endfor %}
            {% endfor %}

            {% block body %}{% endblock %}
        </main>

    </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
{% block javascripts %}{% endblock %}
</body>
</html>
