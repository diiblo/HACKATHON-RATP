{% extends 'base.html.twig' %}

{% block title %}Inbox Sociale — RATP{% endblock %}

{% block body %}
<div class="d-flex justify-content-between align-items-center mb-4">
    <h1 class="h3 mb-0"><i class="bi bi-chat-dots me-2 text-primary"></i>Inbox sociale simulée</h1>
    <span class="text-muted small">Connecteurs X / Instagram / Facebook simulés</span>
</div>

<div class="row g-3">
    {% for item in feed %}
    <div class="col-12">
        <div class="card">
            <div class="card-body">
                <div class="d-flex justify-content-between align-items-start flex-wrap gap-2 mb-2">
                    <div>
                        <div class="fw-semibold">{{ item.title }}</div>
                        <div class="text-muted small">{{ item.platform }} · {{ item.author }} · {{ item.publishedAt|date('d/m/Y H:i') }}</div>
                    </div>
                    <span class="badge bg-secondary">{{ item.language|upper }}</span>
                </div>
                <p class="mb-3">{{ item.content }}</p>
                <div class="text-muted small mb-3">Ligne {{ item.line }} · Véhicule {{ item.vehicle }} · Arrêt {{ item.stop }}</div>
                <form method="post" action="{{ path('app_social_import', {id: item.id}) }}" data-turbo="false">
                    <button type="submit" class="btn btn-outline-primary btn-sm">
                        <i class="bi bi-box-arrow-in-down me-1"></i>Importer comme signalement
                    </button>
                </form>
            </div>
        </div>
    </div>
    {% endfor %}
</div>
{% endblock %}
