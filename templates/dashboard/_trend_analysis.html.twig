{% if error is defined and error %}
<div class="alert alert-danger d-flex align-items-center gap-3">
    <i class="bi bi-exclamation-triangle-fill fs-4"></i>
    <div><strong>Analyse indisponible</strong> — {{ error }}</div>
</div>
{% elseif analysis %}
<div class="card border-primary mt-3" id="trend-result">
    <div class="card-header bg-primary text-white d-flex justify-content-between align-items-center">
        <h6 class="mb-0"><i class="bi bi-graph-up-arrow me-2"></i>Analyse des tendances — {{ analysis.provider }}</h6>
        <div class="d-flex align-items-center gap-2">
            {% if analysis.usedFallback %}
                <span class="badge bg-warning text-dark"><i class="bi bi-shuffle me-1"></i>Bascule IA</span>
            {% endif %}
            {% set alertClass = analysis.niveauAlerte == 'critique' ? 'bg-danger' : (analysis.niveauAlerte == 'attention' ? 'bg-warning text-dark' : 'bg-success') %}
            <span class="badge {{ alertClass }}">{{ analysis.niveauAlerte|upper }}</span>
        </div>
    </div>
    <div class="card-body">
        <div class="mb-3">
            <div class="fw-semibold text-muted small text-uppercase mb-1">Résumé exécutif</div>
            <p class="mb-0">{{ analysis.resume }}</p>
        </div>
        {% if analysis.tendances %}
        <div class="mb-3">
            <div class="fw-semibold text-muted small text-uppercase mb-1">Tendances détectées</div>
            <p class="mb-0 text-secondary">{{ analysis.tendances }}</p>
        </div>
        {% endif %}
        <div class="row g-3">
            {% if analysis.risques|length > 0 %}
            <div class="col-md-6">
                <div class="fw-semibold text-muted small text-uppercase mb-2">Risques identifiés</div>
                <ul class="mb-0 ps-3">
                    {% for risque in analysis.risques %}
                        <li class="text-danger mb-1">{{ risque }}</li>
                    {% endfor %}
                </ul>
            </div>
            {% endif %}
            {% if analysis.recommandations|length > 0 %}
            <div class="col-md-6">
                <div class="fw-semibold text-muted small text-uppercase mb-2">Actions recommandées</div>
                <ul class="mb-0 ps-3">
                    {% for rec in analysis.recommandations %}
                        <li class="text-success mb-1">{{ rec }}</li>
                    {% endfor %}
                </ul>
            </div>
            {% endif %}
        </div>
    </div>
</div>
{% endif %}
