{% extends 'base.html.twig' %}

{% block title %}Tableau de bord — RATP{% endblock %}

{% block body %}
{# Toast notification live #}
<div class="position-fixed top-0 end-0 p-3" style="z-index:1100" id="live-toast-container"></div>

<div class="d-flex justify-content-between align-items-center mb-4">
    <h1 class="h3 mb-0">
        <i class="bi bi-speedometer2 me-2 text-primary"></i>Tableau de bord
        <span id="live-badge" class="badge bg-danger ms-2 d-none" style="animation: pulse 1s infinite">
            <i class="bi bi-bell-fill me-1"></i><span id="live-badge-text"></span>
        </span>
    </h1>
    <div class="d-flex align-items-center gap-2">
        {% if is_granted('ROLE_MANAGER') %}
        <span class="text-muted small"><i class="bi bi-circle-fill text-success me-1" style="font-size:0.5rem"></i>Live</span>
        <a href="{{ path('app_signalement_new') }}" class="btn btn-primary">
            <i class="bi bi-plus-circle me-1"></i> Nouveau signalement
        </a>
        {% elseif is_granted('ROLE_RH') %}
        <a href="{{ path('app_courrier_index') }}" class="btn btn-primary">
            <i class="bi bi-envelope-paper me-1"></i> Ouvrir la file RH
        </a>
        {% endif %}
    </div>
</div>

{% if is_granted('ROLE_RH') %}
<div class="card mb-4 border-warning">
    <div class="card-body d-flex flex-column flex-lg-row justify-content-between align-items-lg-center gap-3">
        <div>
            <div class="small text-uppercase text-muted mb-1">File RH</div>
            <div class="h5 mb-1">{{ courrierStats.enValidation }} courrier(s) à valider</div>
            <div class="text-muted small">{{ courrierStats.valide }} courrier(s) déjà validé(s) disponibles dans la file RH.</div>
        </div>
        <div class="d-flex gap-2 flex-wrap">
            <a href="{{ path('app_courrier_index') }}" class="btn btn-warning">
                <i class="bi bi-envelope-check me-1"></i> Ouvrir la file RH
            </a>
        </div>
    </div>
</div>
{% endif %}

<div class="card mb-4 border-0 bg-primary text-white">
    <div class="card-body">
        <div class="row g-3 align-items-center">
            <div class="col-lg-4">
                <div class="small text-uppercase opacity-75 mb-1">IA décisionnelle</div>
                <div class="h5 mb-1">Tri automatique, aide à la décision et résilience multi-fournisseurs</div>
                <div class="small opacity-75">OpenRouter, Gemini et Ollama Cloud peuvent se relayer automatiquement.</div>
            </div>
            <div class="col-lg-8">
                <div class="row g-3">
                    <div class="col-4">
                        <div class="bg-white text-dark rounded-4 p-3 h-100">
                            <div class="small text-muted">Pré-tris IA</div>
                            <div class="fs-3 fw-bold">{{ aiStats.preTriageCount }}</div>
                        </div>
                    </div>
                    <div class="col-4">
                        <div class="bg-white text-dark rounded-4 p-3 h-100">
                            <div class="small text-muted">Analyses IA</div>
                            <div class="fs-3 fw-bold">{{ aiStats.analysisCount }}</div>
                        </div>
                    </div>
                    <div class="col-4">
                        <div class="bg-white text-dark rounded-4 p-3 h-100">
                            <div class="small text-muted">Fallbacks</div>
                            <div class="fs-3 fw-bold">{{ aiStats.failoverCount }}</div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

{# Alertes agents #}
{% if agentsCritiques|length > 0 %}
<div class="alert alert-danger d-flex align-items-center gap-3 mb-3" role="alert">
    <i class="bi bi-exclamation-octagon-fill fs-4"></i>
    <div>
        <strong>{{ agentsCritiques|length }} agent(s) en CRITIQUE</strong> — niveau 4/4.
        {% for item in agentsCritiques %}
            <a href="{{ path('app_agent_show', {id: item.agent.id}) }}" class="badge bg-danger text-decoration-none ms-1">
                {{ item.agent.fullName }} (niv. {{ item.level }}/4, brut {{ item.rawScore }})
            </a>
        {% endfor %}
    </div>
</div>
{% endif %}

{% if agentsEnAlerte|length > 0 %}
<div class="alert alert-warning d-flex align-items-center gap-3 mb-4" role="alert">
    <i class="bi bi-exclamation-triangle-fill fs-4"></i>
    <div>
        <strong>{{ agentsEnAlerte|length }} agent(s) en ALERTE</strong> — niveau 3/4.
        {% for item in agentsEnAlerte %}
            <a href="{{ path('app_agent_show', {id: item.agent.id}) }}" class="badge bg-warning text-dark text-decoration-none ms-1">
                {{ item.agent.fullName }} (niv. {{ item.level }}/4, brut {{ item.rawScore }})
            </a>
        {% endfor %}
    </div>
</div>
{% endif %}

{% if videoUrgentSignalements|length > 0 %}
<div class="alert alert-info d-flex align-items-center gap-3 mb-4" role="alert">
    <i class="bi bi-camera-video-fill fs-4"></i>
    <div>
        <strong>Conservation vidéo à surveiller</strong>
        {% for s in videoUrgentSignalements %}
            <a href="{{ path('app_signalement_show', {id: s.id}) }}" class="badge bg-info text-dark text-decoration-none ms-1">
                #{{ s.id }} · {{ s.videoHoursRemaining }}h restantes
            </a>
        {% endfor %}
    </div>
</div>
{% endif %}

{# Statistiques — ids pour mise à jour live #}
<div class="row g-3 mb-4">
    <div class="col-6 col-md-2">
        <div class="card stat-card h-100">
            <div class="card-body text-center py-3">
                <div class="fs-2 fw-bold text-primary" id="stat-total">{{ stats.total }}</div>
                <div class="small text-muted">Total</div>
            </div>
        </div>
    </div>
    <div class="col-6 col-md-2">
        <div class="card h-100 border-start border-secondary border-3">
            <div class="card-body text-center py-3">
                <div class="fs-2 fw-bold text-secondary" id="stat-nouveau">{{ stats.nouveau }}</div>
                <div class="small text-muted">Nouveaux</div>
            </div>
        </div>
    </div>
    <div class="col-6 col-md-2">
        <div class="card h-100 border-start border-info border-3">
            <div class="card-body text-center py-3">
                <div class="fs-2 fw-bold text-info" id="stat-qualification">{{ stats.qualification }}</div>
                <div class="small text-muted">Qualification</div>
            </div>
        </div>
    </div>
    <div class="col-6 col-md-2">
        <div class="card h-100 border-start border-warning border-3">
            <div class="card-body text-center py-3">
                <div class="fs-2 fw-bold text-warning" id="stat-validation">{{ stats.validation }}</div>
                <div class="small text-muted">Validation</div>
            </div>
        </div>
    </div>
    <div class="col-6 col-md-2">
        <div class="card h-100 border-start border-success border-3">
            <div class="card-body text-center py-3">
                <div class="fs-2 fw-bold text-success" id="stat-traite">{{ stats.traite }}</div>
                <div class="small text-muted">Traités</div>
            </div>
        </div>
    </div>
    <div class="col-6 col-md-2">
        <div class="card h-100 border-start border-dark border-3">
            <div class="card-body text-center py-3">
                <div class="fs-2 fw-bold text-dark" id="stat-archive">{{ stats.archive }}</div>
                <div class="small text-muted">Archivés</div>
            </div>
        </div>
    </div>
</div>

{% if aiStats.recentEvents is not empty %}
<div class="card mb-4">
    <div class="card-header d-flex justify-content-between align-items-center">
        <h6 class="mb-0"><i class="bi bi-stars me-2"></i>Activité IA récente</h6>
        {% if is_granted('ROLE_DEV') %}
        <a href="{{ path('app_admin_audit') }}" class="btn btn-sm btn-outline-primary">Voir l'audit</a>
        {% endif %}
    </div>
    <div class="card-body">
        <div class="row g-3">
            {% for event in aiStats.recentEvents %}
            <div class="col-md-6">
                <div class="border rounded-4 p-3 h-100">
                    <div class="d-flex justify-content-between align-items-start gap-2 mb-2">
                        <div class="fw-semibold">{{ event.summary }}</div>
                        <span class="badge bg-light text-dark">{{ event.action }}</span>
                    </div>
                    <div class="small text-muted">{{ event.createdAt|date('d/m/Y H:i') }} · {{ event.actorLabel }}</div>
                </div>
            </div>
            {% endfor %}
        </div>
    </div>
</div>
{% endif %}

{% if is_granted('ROLE_MANAGER') %}
<div class="card mb-4 border-0 shadow-sm">
    <div class="card-body">
        <div class="d-flex justify-content-between align-items-center">
            <div>
                <h6 class="mb-1"><i class="bi bi-graph-up-arrow me-2 text-primary"></i>Analyse des tendances IA</h6>
                <div class="small text-muted">Détection de patterns sur les 30 derniers jours vs les 30 jours précédents.</div>
            </div>
            <form method="post" action="{{ path('app_dashboard_analyser_tendances') }}" id="trend-form">
                <input type="hidden" name="_token" value="{{ csrf_token('trend-analysis') }}">
                <button type="submit" class="btn btn-outline-primary" id="trend-btn">
                    <i class="bi bi-stars me-1"></i>Analyser les tendances
                </button>
            </form>
        </div>
        <div id="trend-result-container"></div>
    </div>
</div>
{% endif %}

<div class="row g-3 mb-4">
    <div class="col-lg-4">
        <div class="card h-100">
            <div class="card-header"><h6 class="mb-0">Répartition par statut</h6></div>
            <div class="card-body"><canvas id="chartStatut" height="220"></canvas></div>
        </div>
    </div>
    <div class="col-lg-4">
        <div class="card h-100">
            <div class="card-header"><h6 class="mb-0">Répartition par type</h6></div>
            <div class="card-body"><canvas id="chartType" height="220"></canvas></div>
        </div>
    </div>
    <div class="col-lg-4">
        <div class="card h-100">
            <div class="card-header"><h6 class="mb-0">Répartition par gravité</h6></div>
            <div class="card-body"><canvas id="chartGravite" height="220"></canvas></div>
        </div>
    </div>
</div>

{# Signalements récents #}
<div class="card">
    <div class="card-header d-flex justify-content-between align-items-center">
        <h5 class="mb-0"><i class="bi bi-clock-history me-2"></i>Signalements récents</h5>
        <a href="{{ path('app_signalement_index') }}" class="btn btn-sm btn-outline-primary">Voir tout</a>
    </div>
    <div class="card-body p-0">
        {% if recentSignalements|length == 0 %}
            <p class="text-muted text-center py-4 mb-0">Aucun signalement pour le moment.</p>
        {% else %}
        <div class="table-responsive">
            <table class="table table-hover mb-0">
                <thead class="table-light">
                    <tr>
                        <th>Date</th>
                        <th>Agent</th>
                        <th>Titre</th>
                        <th>Type</th>
                        <th>Gravité</th>
                        <th>Statut</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                    {% for s in recentSignalements %}
                    <tr>
                        <td class="text-muted small">{{ s.dateFait|date('d/m/Y') }}</td>
                        <td>
                            {% if s.agent %}
                                <a href="{{ path('app_agent_show', {id: s.agent.id}) }}" class="text-decoration-none">
                                    {{ s.agent.fullName }}
                                </a>
                                <div class="text-muted small">{{ s.agent.centre ?? '' }}</div>
                            {% else %}
                                <span class="text-muted fst-italic">À identifier</span>
                                {% if s.agentDescription %}
                                <div class="text-muted small">{{ s.agentDescription|u.truncate(30, '…') }}</div>
                                {% endif %}
                            {% endif %}
                        </td>
                        <td>{{ s.titre|u.truncate(50, '…') }}</td>
                        <td>
                            {% if s.type == 'incident' %}
                                <span class="badge bg-danger"><i class="bi bi-flag-fill me-1"></i>Incident</span>
                            {% else %}
                                <span class="badge bg-success"><i class="bi bi-hand-thumbs-up-fill me-1"></i>Positif</span>
                            {% endif %}
                        </td>
                        <td>
                            {% if s.gravite %}
                                <span class="badge {{ s.graviteBadge }}">{{ s.gravite|capitalize }}</span>
                            {% else %}
                                <span class="text-muted">—</span>
                            {% endif %}
                        </td>
                        <td>
                            <span class="badge {{ s.statutBadge }}">{{ s.statutLabel }}</span>
                        </td>
                        <td>
                            <a href="{{ path('app_signalement_show', {id: s.id}) }}"
                               class="btn btn-sm btn-outline-secondary">
                                <i class="bi bi-eye"></i>
                            </a>
                        </td>
                    </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
        {% endif %}
    </div>
</div>
{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <style>
        @keyframes pulse { 0%,100%{opacity:1} 50%{opacity:.4} }
    </style>
{% endblock %}

{% block javascripts %}
    {{ parent() }}
    <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.3/dist/chart.umd.min.js"></script>
    <script>
        const statutData = {{ {
            labels: ['Nouveau', 'Qualification', 'Validation', 'Traité', 'Archivé'],
            values: [stats.nouveau, stats.qualification, stats.validation, stats.traite, stats.archive]
        }|json_encode|raw }};
        const typeData = {{ {
            labels: ['Incident', 'Positif'],
            values: [typeStats.incident, typeStats.positif]
        }|json_encode|raw }};
        const graviteData = {{ {
            labels: ['Faible', 'Moyen', 'Grave'],
            values: [graviteStats.faible, graviteStats.moyen, graviteStats.grave]
        }|json_encode|raw }};

        const buildChart = (id, labels, values, colors) => {
            new Chart(document.getElementById(id), {
                type: 'doughnut',
                data: { labels, datasets: [{ data: values, backgroundColor: colors, borderWidth: 0 }] },
                options: { plugins: { legend: { position: 'bottom' } } }
            });
        };

        buildChart('chartStatut', statutData.labels, statutData.values, ['#6c757d', '#0dcaf0', '#ffc107', '#198754', '#212529']);
        buildChart('chartType', typeData.labels, typeData.values, ['#dc3545', '#198754']);
        buildChart('chartGravite', graviteData.labels, graviteData.values, ['#198754', '#ffc107', '#dc3545']);

        /* ─── LIVE POLLING ─── */
        let lastTotal = {{ stats.total }};
        let lastCritiquesCount = {{ agentsCritiques|length }};

        function showToast(msg, type = 'danger') {
            const id = 'toast-' + Date.now();
            const html = `<div id="${id}" class="toast align-items-center text-bg-${type} border-0 show mb-2" role="alert">
                <div class="d-flex">
                    <div class="toast-body fw-semibold">${msg}</div>
                    <button type="button" class="btn-close btn-close-white me-2 m-auto" onclick="document.getElementById('${id}').remove()"></button>
                </div>
            </div>`;
            document.getElementById('live-toast-container').insertAdjacentHTML('beforeend', html);
            setTimeout(() => { const el = document.getElementById(id); if(el) el.remove(); }, 6000);
        }

        function updateStat(id, value) {
            const el = document.getElementById(id);
            if (el && el.textContent != value) {
                el.textContent = value;
                el.classList.add('text-primary');
                setTimeout(() => el.classList.remove('text-primary'), 1500);
            }
        }

        async function pollDashboard() {
            try {
                const resp = await fetch('{{ path('app_dashboard_live') }}');
                if (!resp.ok) return;
                const data = await resp.json();

                updateStat('stat-total', data.stats.total);
                updateStat('stat-nouveau', data.stats.nouveau);
                updateStat('stat-qualification', data.stats.qualification);
                updateStat('stat-validation', data.stats.validation);
                updateStat('stat-traite', data.stats.traite);
                updateStat('stat-archive', data.stats.archive);

                if (data.recentlyAdded > 0) {
                    const badge = document.getElementById('live-badge');
                    document.getElementById('live-badge-text').textContent = data.recentlyAdded + ' nouveau' + (data.recentlyAdded > 1 ? 'x' : '');
                    badge.classList.remove('d-none');
                    setTimeout(() => badge.classList.add('d-none'), 10000);
                    showToast(`🔔 ${data.recentlyAdded} nouveau(x) signalement(s) reçu(s) !`, 'danger');
                }

                if (data.critiques.length > lastCritiquesCount) {
                    showToast(`⚠️ Nouvel agent en niveau CRITIQUE !`, 'warning');
                }
                lastTotal = data.stats.total;
                lastCritiquesCount = data.critiques.length;
            } catch(e) { /* silencieux */ }
        }

        setInterval(pollDashboard, 30000);

        /* ─── ANALYSE TENDANCES ─── */
        const trendForm = document.getElementById('trend-form');
        if (trendForm) {
            trendForm.addEventListener('submit', async (e) => {
                e.preventDefault();
                const btn = document.getElementById('trend-btn');
                const container = document.getElementById('trend-result-container');
                btn.disabled = true;
                btn.innerHTML = '<span class="spinner-border spinner-border-sm me-1"></span>Analyse en cours…';
                container.innerHTML = '';
                try {
                    const resp = await fetch(trendForm.action, { method: 'POST', body: new FormData(trendForm) });
                    container.innerHTML = await resp.text();
                    container.querySelector('#trend-result')?.scrollIntoView({ behavior: 'smooth' });
                } catch(e) {
                    container.innerHTML = '<div class="alert alert-danger mt-3">Erreur lors de l\'analyse.</div>';
                } finally {
                    btn.disabled = false;
                    btn.innerHTML = '<i class="bi bi-stars me-1"></i>Relancer l\'analyse';
                }
            });
        }
    </script>
{% endblock %}
