{{ form_start(form, {attr: {novalidate: 'novalidate'}}) }}

<div class="row g-3">
    <div class="col-md-4">
        <label class="form-label fw-medium">Matricule <span class="text-danger">*</span></label>
        {{ form_widget(form.matricule) }}
        {{ form_errors(form.matricule) }}
    </div>
    <div class="col-md-4">
        <label class="form-label fw-medium">Nom <span class="text-danger">*</span></label>
        {{ form_widget(form.nom) }}
        {{ form_errors(form.nom) }}
    </div>
    <div class="col-md-4">
        <label class="form-label fw-medium">Prénom <span class="text-danger">*</span></label>
        {{ form_widget(form.prenom) }}
        {{ form_errors(form.prenom) }}
    </div>
    <div class="col-md-6">
        <label class="form-label fw-medium">Centre d'affectation</label>
        {{ form_widget(form.centre) }}
        {{ form_errors(form.centre) }}
    </div>
    <div class="col-md-6">
        <label class="form-label fw-medium">Date de naissance</label>
        {{ form_widget(form.dateNaissance) }}
        {{ form_errors(form.dateNaissance) }}
    </div>
    <div class="col-12">
        <div class="form-check">
            {{ form_widget(form.actif) }}
            <label class="form-check-label">Agent actif</label>
        </div>
    </div>
</div>

<div class="d-flex gap-2 mt-4">
    <button type="submit" class="btn btn-primary">
        <i class="bi bi-check-circle me-1"></i> Enregistrer
    </button>
    <a href="{{ path('app_agent_index') }}" class="btn btn-outline-secondary">Annuler</a>
</div>

{{ form_end(form) }}
