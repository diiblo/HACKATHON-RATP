{% extends 'base.html.twig' %}
{% block title %}Modifier signalement — {{ signalement.titre }}{% endblock %}
{% block body %}
<div class="mb-4">
    <nav aria-label="breadcrumb">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a href="{{ path('app_signalement_index') }}">Signalements</a></li>
            <li class="breadcrumb-item"><a href="{{ path('app_signalement_show', {id: signalement.id}) }}">{{ signalement.titre|u.truncate(30, '…') }}</a></li>
            <li class="breadcrumb-item active">Modifier</li>
        </ol>
    </nav>
    <h1 class="h3"><i class="bi bi-pencil me-2 text-primary"></i>Modifier le signalement</h1>
</div>
<div class="card">
    <div class="card-body">
        {% include 'signalement/_form.html.twig' %}
    </div>
</div>
{% endblock %}
