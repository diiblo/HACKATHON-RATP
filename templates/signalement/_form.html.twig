{{ form_start(form, {attr: {novalidate: 'novalidate', 'data-turbo': 'false'}}) }}

<div class="row g-3">
    <div class="col-md-6">
        <label class="form-label fw-medium">Agent concerné <span class="text-danger">*</span></label>
        {{ form_widget(form.agent) }}
        {{ form_errors(form.agent) }}
    </div>
    <div class="col-md-3">
        <label class="form-label fw-medium">Type <span class="text-danger">*</span></label>
        {{ form_widget(form.type) }}
        {{ form_errors(form.type) }}
    </div>
    <div class="col-md-3">
        <label class="form-label fw-medium">Canal <span class="text-danger">*</span></label>
        {{ form_widget(form.canal) }}
        {{ form_errors(form.canal) }}
    </div>
    <div class="col-12">
        <label class="form-label fw-medium">Titre <span class="text-danger">*</span></label>
        {{ form_widget(form.titre) }}
        {{ form_errors(form.titre) }}
    </div>
    <div class="col-md-8">
        <label class="form-label fw-medium">Description des faits <span class="text-danger">*</span></label>
        {{ form_widget(form.description) }}
        {{ form_errors(form.description) }}
    </div>
    <div class="col-md-2">
        <label class="form-label fw-medium">Date des faits <span class="text-danger">*</span></label>
        {{ form_widget(form.dateFait) }}
        {{ form_errors(form.dateFait) }}
    </div>
    <div class="col-md-2" id="gravite-wrapper">
        <label class="form-label fw-medium">Gravité</label>
        {{ form_widget(form.gravite) }}
        {{ form_errors(form.gravite) }}
        <div class="form-text">Uniquement pour les incidents</div>
    </div>
</div>

<div class="d-flex gap-2 mt-4">
    <button type="submit" class="btn btn-primary">
        <i class="bi bi-check-circle me-1"></i> Enregistrer
    </button>
    <a href="{{ path('app_signalement_index') }}" class="btn btn-outline-secondary">Annuler</a>
</div>

{{ form_end(form) }}

<script>
(function() {
    const typeSelect = document.getElementById('signalement_type');
    const graviteWrapper = document.getElementById('gravite-wrapper');
    const graviteSelect = document.getElementById('signalement_gravite');

    function toggleGravite() {
        const isIncident = typeSelect && typeSelect.value === 'incident';
        if (graviteWrapper) {
            graviteWrapper.style.opacity = isIncident ? '1' : '0.4';
        }
        if (graviteSelect) {
            graviteSelect.disabled = !isIncident;
            if (!isIncident) graviteSelect.value = '';
        }
    }

    if (typeSelect) {
        typeSelect.addEventListener('change', toggleGravite);
        toggleGravite();
    }
})();
</script>
