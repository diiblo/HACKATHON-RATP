{% extends 'base.html.twig' %}

{% block title %}Audit — RATP{% endblock %}

{% block body %}
<div class="d-flex justify-content-between align-items-center mb-4">
    <h1 class="h3 mb-0"><i class="bi bi-journal-text me-2 text-primary"></i>Journal d'audit</h1>
    <span class="text-muted small">200 derniers événements</span>
</div>

<div class="card">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover mb-0">
                <thead class="table-light">
                    <tr>
                        <th>Date</th>
                        <th>Action</th>
                        <th>Acteur</th>
                        <th>Sujet</th>
                        <th>Résumé</th>
                    </tr>
                </thead>
                <tbody>
                {% for log in logs %}
                    <tr>
                        <td class="small text-muted">{{ log.createdAt|date('d/m/Y H:i:s') }}</td>
                        <td><code>{{ log.action }}</code></td>
                        <td>{{ log.actorLabel }}</td>
                        <td>{{ log.subjectType ?: '—' }}{% if log.subjectId %} #{{ log.subjectId }}{% endif %}</td>
                        <td>{{ log.summary }}</td>
                    </tr>
                {% else %}
                    <tr><td colspan="5" class="text-center text-muted py-4">Aucun événement audit.</td></tr>
                {% endfor %}
                </tbody>
            </table>
        </div>
    </div>
</div>
{% endblock %}
