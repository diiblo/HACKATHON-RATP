{% extends 'base.html.twig' %}
{% block title %}Utilisateurs — RATP{% endblock %}
{% block body %}
<div class="d-flex justify-content-between align-items-center mb-4">
    <h1 class="h3 mb-0"><i class="bi bi-person-gear me-2 text-primary"></i>Gestion des utilisateurs</h1>
    <a href="{{ path('app_admin_user_new') }}" class="btn btn-primary">
        <i class="bi bi-person-plus me-1"></i>Nouvel utilisateur
    </a>
</div>

<div class="card">
    <div class="card-body p-0">
        <table class="table table-hover mb-0">
            <thead class="table-light">
                <tr>
                    <th>Nom</th>
                    <th>E-mail</th>
                    <th>Rôle</th>
                    <th>Centre</th>
                    <th>Statut</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                {% for user in users %}
                <tr>
                    <td class="fw-medium">{{ user.fullName }}</td>
                    <td>{{ user.email }}</td>
                    <td>
                        {% for role in user.roles %}
                            {% if role != 'ROLE_USER' %}
                            <span class="badge bg-primary me-1">{{ role|replace({'ROLE_': ''})|capitalize }}</span>
                            {% endif %}
                        {% endfor %}
                    </td>
                    <td>{{ user.centre ?? '—' }}</td>
                    <td>
                        {% if user.actif %}
                            <span class="badge bg-success">Actif</span>
                        {% else %}
                            <span class="badge bg-secondary">Inactif</span>
                        {% endif %}
                    </td>
                    <td>
                        <a href="{{ path('app_admin_user_edit', {id: user.id}) }}" class="btn btn-sm btn-outline-primary">
                            <i class="bi bi-pencil"></i>
                        </a>
                    </td>
                </tr>
                {% endfor %}
            </tbody>
        </table>
    </div>
</div>
{% endblock %}
