{% extends 'base.html.twig' %}

{% block title %}IA — Configurations{% endblock %}

{% block body %}
<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h1 class="h3 mb-0"><i class="bi bi-cpu me-2 text-primary"></i>Configurations IA</h1>
        <div class="text-muted small">Ordre de secours automatique : configuration par défaut, puis autres connecteurs actifs.</div>
    </div>
    <a href="{{ path('app_admin_ai_config_new') }}" class="btn btn-primary">
        <i class="bi bi-plus-circle me-1"></i>Nouvelle configuration
    </a>
</div>

<div class="card">
    <div class="card-body p-0">
        <table class="table table-hover mb-0">
            <thead class="table-light">
            <tr>
                <th>Nom</th>
                <th>Type</th>
                <th>Fournisseur</th>
                <th>Modèle</th>
                <th>Timeout</th>
                <th>Clé API</th>
                <th>Statut</th>
                <th></th>
            </tr>
            </thead>
            <tbody>
            {% for config in configs %}
                <tr>
                    <td class="fw-medium">{{ config.name }}</td>
                    <td>{{ constant('App\\\\Entity\\\\AiProviderConfig::PROVIDER_TYPES')[config.providerType] ?? config.providerType }}</td>
                    <td>{{ config.vendorLabel ?: '—' }}</td>
                    <td><code>{{ config.model }}</code></td>
                    <td>{{ config.timeoutSeconds }}s</td>
                    <td>
                        {% if config.hasApiKey %}
                            <span class="text-success">Oui</span>
                        {% else %}
                            <span class="text-muted">Non</span>
                        {% endif %}
                    </td>
                    <td>
                        {% if config.active %}
                            <span class="badge bg-success">Active</span>
                        {% else %}
                            <span class="badge bg-secondary">Inactive</span>
                        {% endif %}
                        {% if config.isDefault %}
                            <span class="badge bg-primary">Par défaut</span>
                        {% endif %}
                    </td>
                    <td>
                        <a href="{{ path('app_admin_ai_config_edit', {id: config.id}) }}" class="btn btn-sm btn-outline-primary">
                            <i class="bi bi-pencil"></i>
                        </a>
                    </td>
                </tr>
            {% else %}
                <tr><td colspan="8" class="text-center text-muted py-4">Aucune configuration IA.</td></tr>
            {% endfor %}
            </tbody>
        </table>
    </div>
</div>
{% endblock %}
