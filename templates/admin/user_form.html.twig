{% extends 'base.html.twig' %}
{% block title %}{{ user ? 'Modifier ' ~ user.fullName : 'Nouvel utilisateur' }} — RATP{% endblock %}
{% block body %}
<div class="mb-4">
    <nav aria-label="breadcrumb">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a href="{{ path('app_admin_users') }}">Utilisateurs</a></li>
            <li class="breadcrumb-item active">{{ user ? user.fullName : 'Nouveau' }}</li>
        </ol>
    </nav>
    <h1 class="h3">
        <i class="bi bi-person-gear me-2 text-primary"></i>
        {{ user ? 'Modifier l\'utilisateur' : 'Nouvel utilisateur' }}
    </h1>
</div>
<div class="card">
    <div class="card-body">
        {{ form_start(form, {attr: {'data-turbo': 'false'}}) }}
        <div class="row g-3">
            <div class="col-md-6">
                {{ form_row(form.nom) }}
            </div>
            <div class="col-md-6">
                {{ form_row(form.prenom) }}
            </div>
            <div class="col-md-6">
                {{ form_row(form.email) }}
            </div>
            <div class="col-md-6">
                {{ form_row(form.centre) }}
            </div>
            <div class="col-md-6">
                {{ form_row(form.roles) }}
            </div>
            <div class="col-md-6">
                {{ form_row(form.plainPassword) }}
            </div>
            <div class="col-12">
                <div class="form-check">
                    {{ form_widget(form.actif) }}
                    <label class="form-check-label">Compte actif</label>
                </div>
            </div>
        </div>
        <div class="d-flex gap-2 mt-4">
            <button type="submit" class="btn btn-primary">
                <i class="bi bi-check-circle me-1"></i>Enregistrer
            </button>
            <a href="{{ path('app_admin_users') }}" class="btn btn-outline-secondary">Annuler</a>
        </div>
        {{ form_end(form) }}
    </div>
</div>
{% endblock %}
