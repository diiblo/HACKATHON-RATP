<div class="voice-recorder" data-voice-recorder data-input-id="{{ input_id }}">
    <div class="d-flex flex-wrap gap-2 align-items-center mb-3">
        <button type="button" class="btn btn-danger" data-action="start">
            <i class="bi bi-record-circle me-1"></i>Enregistrer un message vocal
        </button>
        <button type="button" class="btn btn-outline-dark d-none" data-action="stop">
            <i class="bi bi-stop-circle me-1"></i>Arrêter
        </button>
        <button type="button" class="btn btn-outline-secondary d-none" data-action="reset">
            <i class="bi bi-arrow-counterclockwise me-1"></i>Effacer
        </button>
        <span class="small text-muted" data-role="status">Appuyez pour enregistrer votre message vocal.</span>
    </div>

    <div class="voice-recorder-live d-none" data-role="live">
        <span class="voice-pulse"></span>
        <strong>Enregistrement en cours</strong>
        <span class="text-muted small ms-2" data-role="timer">00:00</span>
    </div>

    <div class="voice-recorder-preview d-none" data-role="preview">
        <div class="small fw-medium mb-2">Préécoute du message vocal</div>
        <audio controls class="w-100" data-role="audio"></audio>
    </div>

    <div class="small text-muted mt-2">
        Le navigateur demandera l'autorisation d'utiliser le microphone.
    </div>

    <div class="alert alert-warning mt-3 d-none mb-0" data-role="error"></div>
</div>
