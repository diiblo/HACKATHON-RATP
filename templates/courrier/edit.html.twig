{% extends 'base.html.twig' %}
{% block title %}Modifier courrier{% endblock %}
{% block body %}
<div class="mb-4">
    <nav aria-label="breadcrumb">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a href="{{ path('app_signalement_index') }}">Signalements</a></li>
            <li class="breadcrumb-item">
                <a href="{{ path('app_signalement_show', {id: courrier.signalement.id}) }}">Dossier</a>
            </li>
            <li class="breadcrumb-item"><a href="{{ path('app_courrier_show', {id: courrier.id}) }}">Courrier</a></li>
            <li class="breadcrumb-item active">Modifier</li>
        </ol>
    </nav>
    <h1 class="h3"><i class="bi bi-pencil me-2 text-primary"></i>Modifier le courrier</h1>
    <p class="text-muted">Modifiez le texte ci-dessous avant de le soumettre à validation.</p>
</div>
<div class="card">
    <div class="card-body">
        {{ form_start(form, {attr: {'data-turbo': 'false'}}) }}
        {{ form_row(form.contenu) }}
        <div class="d-flex gap-2 mt-3">
            <button type="submit" class="btn btn-primary">
                <i class="bi bi-check-circle me-1"></i>Enregistrer
            </button>
            <a href="{{ path('app_courrier_show', {id: courrier.id}) }}" class="btn btn-outline-secondary">Annuler</a>
        </div>
        {{ form_end(form) }}
    </div>
</div>
{% endblock %}
